# NeuroSynth production environment contract
# Copy to .env.prod and inject real values via your secret manager.

NEURO_JWKS_URL=https://auth.your-domain.com/.well-known/jwks.json
NEURO_ALLOWED_ORIGINS=https://api.your-domain.com,https://console.your-domain.com
NEURO_REDIS_URL=redis://redis.prod.internal:6379/0
NEURO_TIMESCALE_DSN=postgresql://postgres:${TIMESCALE_PASSWORD}@timescale.prod.internal:5432/neurosynth

NEURO_ENTREZ_EMAIL=mlops@your-domain.com
NEURO_KFP_HOST=https://kubeflow.your-domain.com
NEURO_KFP_EXPERIMENT=neurosynth
NEURO_KFP_PIPELINE_ID=
NEURO_KFP_PIPELINE_PACKAGE=

AWS_REGION=us-east-1
AWS_ACCOUNT_ID=
ECR_REPOSITORY=
